# ─── Secrets ───────────────────────────────────────────────────────────
# Real credentials (API keys, Garmin password, initial login). NEVER commit.
# The placeholder template `.env.example` IS committed.
.env
.env.*
!.env.example

# ─── Data & backups (contain user data, bcrypt hashes, plaintext Garmin
#     passwords, OAuth tokens, and all health/GPS history) ────────────────
data/
backups/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Garmin OAuth token caches (in case they ever land outside data/)
garmin_tokens/
garmin_tokens.json

# ─── Python (backend) ──────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ─── Node / Next (frontend) ────────────────────────────────────────────
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / editor / runtime cruft ───────────────────────────────────────
.DS_Store
Thumbs.db
*.pid
.caffeinate.pid
*.log
.idea/
.vscode/
