# --- Security ---
# SECRET_KEY encrypts stored Garmin passwords at rest (any passphrase works).
# Leave it blank to auto-generate a key file under the data volume instead
# (data/.secret_key). If you SET it, keep it stable - changing it makes existing
# stored Garmin passwords undecryptable and they must be re-entered.
SECRET_KEY=
# Session cookie Secure flag (HTTPS-only). Leave true for any real deployment;
# set false only for a plain-HTTP setup with no TLS in front.
COOKIE_SECURE=true

# --- LLM (either provider works; switch anytime in Settings or here) ---
LLM_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.1

# --- First login (created once, when the users table is empty; change the
# --- password right after first login via Settings) ---
INITIAL_USERNAME=will
INITIAL_PASSWORD=changeme

# --- Garmin (seeds the first user's connection; other household members
# --- connect via Settings -> Connect Garmin) ---
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password

# --- Behavior ---
PLAN_HOUR=6                       # local hour the daily sync+replan runs
SYNC_LOOKBACK_DAYS=14
AUTO_PUSH_WORKOUTS=false          # manual by default: use the per-day / whole-week send buttons
BACKFILL_DAYS=300                 # deep-history stage of onboarding
